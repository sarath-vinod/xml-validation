@model List<XMLValidator.Models.XmlValidationError>

@{
    ViewData["Title"] = "Validation Results";
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card shadow-sm">
            @{
                string headerColorClass = Model.Count == 0 ? "bg-success" : "bg-danger";
            }
            <div class="card-header @headerColorClass text-white">
                <h2 class="mb-0 text-center">XML Validation Results</h2>
            </div>
            <div class="card-body">
                @if (Model.Count == 0)
                {
                    <div class="alert alert-success text-center" role="alert">
                        <h4 class="alert-heading">No error found!</h4>
                        <p class="mb-0">The XML file <code>@ViewBag.XmlFileName</code> is valid according to the schema <code>@ViewBag.SchemaFileName</code>.</p>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger mb-3">
                        <p class="mb-0">
                            <strong>Validation Issues Found:</strong> We found <strong>@Model.Count</strong> error(s) in your XML file 
                            <code>@ViewBag.XmlFileName</code> when comparing it to the schema 
                            <code>@ViewBag.SchemaFileName</code>.
                        </p>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-bordered table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th class="text-center">XML Element</th>
                                    <th class="text-center">Error Type</th>
                                    <th class="text-center">Line Number</th>
                                    <th class="text-center">Column Number</th>
                                    <th class="text-center">Error Message</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var error in Model)
                                {
                                    <tr>
                                        <td class="text-center">@error.Element</td>
                                        <td class="text-center">
                                            @{
                                                string badgeColorClass = error.ErrorType == "Error" ? "bg-danger" : "bg-warning";
                                            }
                                            <span class="badge @badgeColorClass">@error.ErrorType</span>
                                        </td>
                                        <td class="text-center"><code>@error.Line</code></td>
                                        <td class="text-center"><code>@error.Column</code></td>
                                        <td>@error.Message</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                
                <div class="mt-3 text-center">
                    <a asp-action="Index" class="btn btn-primary">Validate Another File</a>
                </div>
            </div>
        </div>
    </div>
</div>
