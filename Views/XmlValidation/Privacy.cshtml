@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1 class="mb-4">Privacy Policy</h1>
        
        <div class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Data Collection</h2>
                <p>This XML Validator application processes XML and XSD schema files that you upload for validation purposes. All file processing is performed server-side during the validation process.</p>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">File Storage</h2>
                <p>Uploaded files are processed in memory and are not permanently stored on our servers. Files are only held temporarily during the validation process and are immediately discarded after validation is complete.</p>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Data Security</h2>
                <p>We take data security seriously. All file uploads are processed securely, and no file content is logged or retained beyond the validation session.</p>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Cookies</h2>
                <p>This application may use session cookies to maintain your session state. These cookies are temporary and are deleted when you close your browser.</p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Contact</h2>
                <p class="mb-0">If you have any questions about this Privacy Policy, please contact us through the appropriate channels.</p>
            </div>
        </div>

        <div class="mt-4">
            <a asp-action="Index" class="btn btn-outline-primary">Back to Validator</a>
        </div>
    </div>
</div>
