@model List<XMLValidator.Models.RestaurantOverviewViewModel>
@{
    ViewData["Title"] = "Restaurant Overview";
}

<div class="row">
    <div class="col-12">
        <h1 class="mb-4">Restaurant Overview</h1>
        
        @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                No restaurants found.
            </div>
        }
        else
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m[0].Name)</th>
                        <th>@Html.DisplayNameFor(m => m[0].FoodType)</th>
                        <th>@Html.DisplayNameFor(m => m[0].Rating)</th>
                        <th>@Html.DisplayNameFor(m => m[0].Cost)</th>
                        <th>@Html.DisplayNameFor(m => m[0].City)</th>
                        <th>@Html.DisplayNameFor(m => m[0].ProvinceState)</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.FoodType)</td>
                            <td>@Html.DisplayFor(modelItem => item.Rating)</td>
                            <td>@Html.DisplayFor(modelItem => item.Cost)</td>
                            <td>@Html.DisplayFor(modelItem => item.City)</td>
                            <td>@Html.DisplayFor(modelItem => item.ProvinceState)</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
